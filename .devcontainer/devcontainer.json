{
  "name": "Real-Time Pipeline Dashboard",
  "dockerComposeFile": [
    "../docker/docker-compose.yml"
  ],
  "service": "backend",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  
  "forwardPorts": [3000, 5173, 8080, 9092, 5432],
  "portsAttributes": {
    "5173": { "label": "Frontend Dev Server", "onAutoForward": "openBrowserOnce" },
    "3000": { "label": "Frontend (Docker Compose)", "onAutoForward": "openBrowserOnce" },
    "8080": { "label": "Backend API", "onAutoForward": "notify" },
    "9092": { "label": "Kafka", "onAutoForward": "silent" },
    "5432": { "label": "PostgreSQL", "onAutoForward": "silent" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker"
      ]
    }
  }
}